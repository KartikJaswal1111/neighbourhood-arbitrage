# ─────────────────────────────────────────────────────────────
# ZERO-COST DEMO MODE  (no Anthropic API key needed)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=mock-key-not-needed
USE_MOCK_VISION=true
USE_MOCK_AGENT=true

# ─────────────────────────────────────────────────────────────
# REAL AI MODE  (requires a valid Anthropic API key)
# Uncomment these and comment out the block above
# ─────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-real-key-here
# USE_MOCK_VISION=false
# USE_MOCK_AGENT=false

# ─────────────────────────────────────────────────────────────
# Common settings (same for both modes)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./arbitrage.db
CLAUDE_MODEL=claude-sonnet-4-6

# CORS — comma-separated list of allowed frontend origins.
# In production set this to your Vercel URL:
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
